# B 系统配置
B_SYSTEM_BASE_URL=https://www.bangwo8.com
B_SYSTEM_AUTHORIZATION=Basic your_authorization_token_here
B_SYSTEM_COOKIE=your_cookie_here

# A 系统配置（纷享销客）
A_SYSTEM_BASE_URL=https://open.fxiaoke.com
A_SYSTEM_APP_ID=FSAID_your_app_id
A_SYSTEM_PERMANENT_CODE=your_permanent_code
A_SYSTEM_APP_SECRET=your_app_secret
A_SYSTEM_DEFAULT_MOBILE=16635022959

# 同步配置
SYNC_INTERVAL_MINUTES=3
SYNC_BATCH_SIZE=100

# 日志配置 - 日志保留天数（默认3天）
LOG_RETENTION_DAYS=3